FROM pandoc/latex:3.9

# To find which packages contain a given .sty file:
# tlmgr search --global --file "authblk.sty"
# or, for a font file:
# tlmgr search --global --file "pplr7t.tfm"

RUN tlmgr option repository https://ftp.math.utah.edu/pub/tex/historic/systems/texlive/2025/tlnet-final
RUN tlmgr update --self

# Latex packages
RUN tlmgr install \
    algorithms algorithmicx wrapfig dblfloatfix ifsym preprint \
    sttools mdframed zref needspace titlesec enumitem titling \
    csvsimple changepage multirow extsizes \
    xkeyval xltxtra realscripts

# Fonts
RUN tlmgr install \
    charter helvetic ly1 courier bold-extra cm-mf-extra-bold palatino

# Tabs, images, tables, and layout
RUN tlmgr install \
    tabto-ltx transparent tabu pdfpages ctable pdflscape

# System tools
RUN apk add --update --no-cache python3 bash && ln -sf python3 /usr/bin/python
RUN apk add pipx
RUN pipx install https://github.com/databio/markmeld/archive/refs/heads/master.zip

ENTRYPOINT []
