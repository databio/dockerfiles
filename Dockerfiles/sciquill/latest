FROM pandoc/latex:3.9

# To find which packages contain a given .sty file:
# tlmgr search --global --file "authblk.sty"
# or, for a font file:
# tlmgr search --global --file "pplr7t.tfm"

# TeX Live repository. Using the live tlnet tree tracks whatever version the
# pandoc/latex base image currently ships (as of this commit, TL2026). Content
# floats over time, so this is not fully reproducible — once TL2026's
# `tlnet-final` snapshot is published (typically ~a year after release), pin
# to that snapshot URL instead.
RUN tlmgr option repository https://mirrors.rit.edu/CTAN/systems/texlive/tlnet
# Backup / reproducible pin (switch back once TL2026 tlnet-final exists):
# RUN tlmgr option repository https://texlive.info/historic/systems/texlive/2026/tlnet-final
RUN tlmgr update --self

# Latex packages
RUN tlmgr install \
    algorithms algorithmicx wrapfig dblfloatfix ifsym preprint \
    sttools mdframed zref needspace titlesec enumitem titling \
    csvsimple changepage multirow extsizes \
    xkeyval xltxtra realscripts

# Fonts
RUN tlmgr install \
    charter helvetic ly1 courier bold-extra cm-mf-extra-bold palatino \
    times psnfss newtx txfonts mathpazo tex-gyre tex-gyre-math \
    xpatch xstring kastrup fontaxes

# Tabs, images, tables, and layout
RUN tlmgr install \
    tabto-ltx transparent tabu pdfpages ctable pdflscape

# System tools
RUN apk add --update --no-cache python3 bash && ln -sf python3 /usr/bin/python
RUN apk add pipx
RUN pipx install https://github.com/databio/markmeld/archive/refs/heads/master.zip

ENTRYPOINT []
